# Copy this file to .env.local and fill in the values you need.
# Never commit .env or .env.local files.
# All values are optional for local dev; sensible defaults are applied.

DATABASE_URL="postgresql://neondb_owner:[TU_PASSWORD]@ep-steep-cell-aszpwbsb.c-4.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# YouTube Data API v3 — https://console.cloud.google.com
# Needed only for the highlights feature on player profiles.
YOUTUBE_API_KEY=

# Public site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Secret to protect /api/cron/* endpoints — only required if you wire up
# the ingestion cron. Generate with: node -e "console.log(crypto.randomBytes(24).toString('base64'))"
# CRON_SECRET=

# Encryption key for user-provided AI API keys (AES-256-GCM, at rest).
# Optional in dev (derived from SESSION_SECRET). REQUIRED in production.
# Generate with: node -e "console.log(crypto.randomBytes(32).toString('base64'))"
# ENCRYPTION_KEY=

# Local LLM (Ollama) — install from https://ollama.com/download
# The AI advisor calls http://localhost:11434/v1/chat/completions by default.
# Pull a model with: ollama pull llama3.1:8b
#
# Optional overrides:
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.1:8b
#
# Other good Spanish-capable models:
#   qwen2.5:7b       — excellent Spanish, 4.7GB
#   gemma2:9b        — strong reasoning, 5.4GB
#   mistral          — fast, 4.1GB
#   llama3.2:3b      — light, 2GB, weaker reasoning
