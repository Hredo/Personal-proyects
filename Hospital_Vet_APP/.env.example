# === VetHospital 24h Configuration ===

# Database
DATABASE_URL="file:./vet_hospital.db"

# Authentication
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
AUTH_SECRET="replace-with-a-long-random-secret"

# === Security & Encryption (GDPR Compliance) ===
# Generate secure keys: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
HASH_SALT="your-hash-salt-here-minimum-32-chars"

# === Backup & Disaster Recovery ===
BACKUP_ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
BACKUP_RETENTION_DAYS=90
AUTOMATIC_BACKUP_INTERVAL_HOURS=24

# === Logging & Monitoring ===
LOG_RETENTION_DAYS=90
LOG_LEVEL=info

# === Email Notifications ===
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="noreply@vethospital24h.com"

# Optional (Resend service for transactional emails)
# RESEND_API_KEY="re_xxxxxxxxx"

# === Payment Gateway ===
PAYMENT_PROVIDER="stripe"
STRIPE_PUBLIC_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# === Analytics & Monitoring ===
SENTRY_DSN=""
GOOGLE_ANALYTICS_ID=""

# === Environment ===
NODE_ENV="development"
DEBUG="false"

# === GDPR & Compliance ===
GDPR_CONTROLLER_NAME="VetHospital 24h"
GDPR_CONTROLLER_EMAIL="privacy@vethospital24h.com"
GDPR_DATA_RETENTION_YEARS=3

# === Multi-Tenant (Future) ===
# MULTI_TENANT_ENABLED=false
# CLINIC_SUPPORT_EMAIL=support@vethospital24h.com
